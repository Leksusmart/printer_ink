# Берем официальный базовый образ
FROM node:20-alpine

# Указываем рабочую папку в контейнере
WORKDIR /frontend

# Сначала копируем ТОЛЬКО файлы зависимостей!
# Это нужно для кэширования: Docker не будет заново качать модули, если код изменился, а зависимости — нет.
COPY package*.json ./

# Устанавливаем библиотеки
RUN npm install

# Только теперь копируем весь остальной исходный код проекта
COPY . .

# Показываем порт
EXPOSE 3001

# Запускаем приложение и принудительно биндим на 0.0.0.0
CMD ["npm", "run", "dev", "--", "-H", "0.0.0.0"]
